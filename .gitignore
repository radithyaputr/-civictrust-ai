# CivicTrust AI - Git Ignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Environment
.env
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Data
data/*.db
data/*.db-shm
data/*.db-wal
data/vector_store/*
!data/vector_store/.gitkeep
data/documents/*
!data/documents/.gitkeep

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker
.docker/

# Streamlit
.streamlit/secrets.toml

# Testing
.pytest_cache/
htmlcov/
.coverage