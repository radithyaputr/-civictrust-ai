# =============================================================================
# CivicTrust AI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys before running.
#   cp .env.example .env
#
# TANPA API KEY: Sistem akan otomatis menggunakan Mock LLM untuk development.
# Dengan Mock LLM, sistem tetap berfungsi penuh dengan response simulasi.
# =============================================================================

# ---- App Settings ----
APP_NAME=CivicTrust AI
APP_VERSION=1.0.0
DEBUG=false

# ---- LLM Provider ----
# Supported providers: google, openai, deepseek, qwen, openrouter
# Jika tidak ada API key, sistem otomatis fallback ke Mock LLM
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ---- API Keys (setidaknya satu untuk LLM real) ----
# Biarkan kosong untuk menggunakan Mock LLM
GOOGLE_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENROUTER_API_KEY=

# ---- Database ----
# SQLite (default - untuk development):
DATABASE_URL=sqlite:///./data/civictrust.db
# PostgreSQL (untuk production):
# DATABASE_URL=postgresql://user:pass@host:5432/civictrust

# Supabase (optional, untuk production)
SUPABASE_URL=
SUPABASE_KEY=

# ---- Vector Store ----
VECTOR_STORE_PATH=./data/vector_store
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ---- Security ----
# Generate random 64-char secret key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# API Key Authentication
# Set API_KEY_REQUIRED=true dan API_KEYS untuk mengaktifkan autentikasi
# Format API_KEYS: key1,key2,key3
API_KEY_REQUIRED=false
API_KEYS_STR=

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ORIGINS_STR=http://localhost:8501,http://localhost:8000

# ---- Speech (optional - install openai-whisper + TTS) ----
WHISPER_MODEL=base
TTS_MODEL=tts_models/id/ljspeech-tacotron2-DDC

# ---- OCR (optional - install easyocr) ----
OCR_ENGINE=easyocr

# ---- Analytics ----
ENABLE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=90

# ---- Feature Flags ----
ENABLE_VISION=true
ENABLE_VOICE=true
ENABLE_TRANSLATION=true
ENABLE_MEMORY=true
ENABLE_EXPLAINABILITY=true
ENABLE_TRUST_SCORE=true
ENABLE_ANALYTICS_DASHBOARD=true
ENABLE_RESPONSIBLE_AI=true

# ---- Language ----
DEFAULT_LANGUAGE=id
SUPPORTED_LANGUAGES=id,en,fr,ja,ar
